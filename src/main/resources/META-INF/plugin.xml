<idea-plugin require-restart="true">
    <id>com.miracle.chatx-expert</id>
    <name>Jarvis AI Core</name>
    <vendor email="support@miracle.com" url="https://www.miracle.com/">Miracle</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Jarvis"
                    anchor="right"
                    icon="/img/inner/logo_round13.svg"
                    factoryClass="com.miracle.ui.core.JarvisToolWindowFactory"/>
        <postStartupActivity implementation="com.miracle.listener.JarvisProjectStartupActivity"/>
        <appLifecycleListener implementation="com.miracle.listener.JarvisAppLifeListener"/>
        <notificationGroup id="jarvisNotifications" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="Jarvis.AddSelectionToChat"
                class="com.miracle.ui.core.AddToJarvisChatAction"
                text="Send Selection To Jarvis"
                description="Send the current editor selection to Jarvis chat">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
