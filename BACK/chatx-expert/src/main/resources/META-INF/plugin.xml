<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin require-restart="true">
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.qihoo.finance.lowcode.chatx-expert</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Jarvis • AI软件研发</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor email="support@360shuke.com" url="https://www.qifu.tech/">奇富科技</vendor>

    <depends>Git4Idea</depends>
    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="plugin-java.xml">com.intellij.java</depends>

    <resource-bundle>messages.chatx</resource-bundle>

    <extensionPoints>
        <extensionPoint qualifiedName="ai.chatx.plugin.editorSupport" interface="com.qihoo.finance.lowcode.editor.ChatxEditorSupport" dynamic="true"/>
    </extensionPoints>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <backgroundPostStartupActivity implementation="com.qihoo.finance.lowcode.common.listener.ChatxStartupActivity"/>

        <!--plugins-->
        <toolWindow id="Jarvis" anchor="right"
                    factoryClass="com.qihoo.finance.lowcode.common.factory.ChatXToolWindowFactory"/>
        <toolWindow id="SQL Execute Result" icon="/img/codereview/gitlab_light.svg" anchor="bottom"
                    factoryClass="com.qihoo.finance.lowcode.console.mysql.result.factory.ResultToolWindowFactory" />
        <!--启动相关-->
        <statusBarWidgetFactory id="com.qihoo.finance.lowcode.chatx-expert"
                                implementation="com.qihoo.finance.lowcode.timetracker.factory.TimeTrackerWidgetFactory"
                                order="before memoryUsageWidget, after writeActionWidget"/>

        <projectService serviceImplementation="com.qihoo.finance.lowcode.timetracker.service.PostTimeTrackerService"/>
        <applicationService
                serviceImplementation="com.qihoo.finance.lowcode.timetracker.configuration.DefaultSettingsService"/>"
        <applicationService serviceImplementation="com.qihoo.finance.lowcode.timetracker.service.InactivityService"/>"


        <applicationService
                serviceImplementation="com.qihoo.finance.lowcode.common.configuration.UserInfoPersistentState"/>
        <applicationService
                serviceImplementation="com.qihoo.finance.lowcode.common.configuration.UserContextPersistent"/>

        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.ui.MainPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.ui.TabPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.ui.LoginPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.ui.OAuth2LoginPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.action.UserInfoAction"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.action.ChatHistoryAction"/>


        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.ui.DatabaseMainPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.ui.ToolBarPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.ui.tree.MySQLTreePanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.ui.tree.MongoTreePanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.ui.tree.MultiDatasourceTreePanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.ui.DatabaseTreePanelFactory"/>

        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.dialog.DatabaseConfigPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.dialog.DatabaseIndexPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.dialog.DatabaseIndexFieldSelectPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.design.dialog.DatabasePreviewPanel"/>

        <!--SQL查询-->
        <virtualFileSystem key="mysql" implementationClass="com.qihoo.finance.lowcode.console.mysql.editor.SQLFileSystem"/>
        <fileEditorProvider implementation="com.qihoo.finance.lowcode.console.mysql.editor.SQLEditorProvider"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.console.mysql.result.ui.ResultView"/>
        <!--mongo查询-->
        <virtualFileSystem key="mongo" implementationClass="com.qihoo.finance.lowcode.console.mongo.view.editor.MongoFileSystem"/>
        <fileEditorProvider implementation="com.qihoo.finance.lowcode.console.mongo.view.editor.MongoEditorProvider"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.console.mongo.MongoEditorManager"/>
        <projectService serviceInterface="com.qihoo.finance.lowcode.console.mongo.logic.Notifier"
                        serviceImplementation="com.qihoo.finance.lowcode.console.mongo.logic.Notifier"/>

        <!--generateTrack-->
        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.util.DataContext"/>
        <applicationService serviceInterface="com.qihoo.finance.lowcode.gentracker.service.SettingsStorageService"
                            serviceImplementation="com.qihoo.finance.lowcode.gentracker.service.impl.SettingsStorageServiceImpl"/>
        <projectService serviceInterface="com.qihoo.finance.lowcode.gentracker.service.TableInfoSettingsService"
                        serviceImplementation="com.qihoo.finance.lowcode.gentracker.service.impl.TableInfoSettingsServiceImpl"/>
        <projectService serviceInterface="com.qihoo.finance.lowcode.gentracker.service.MySQLGenerateService"
                        serviceImplementation="com.qihoo.finance.lowcode.gentracker.service.impl.MySQLGenerateServiceImpl"/>
        <projectService serviceInterface="com.qihoo.finance.lowcode.gentracker.service.MongoGenerateService"
                        serviceImplementation="com.qihoo.finance.lowcode.gentracker.service.impl.MongoGenerateServiceImpl"/>
        <applicationService serviceInterface="com.qihoo.finance.lowcode.gentracker.service.GenerateRecordService"
                            serviceImplementation="com.qihoo.finance.lowcode.gentracker.service.impl.GenerateRecordServiceImpl"/>
        <applicationService serviceInterface="com.qihoo.finance.lowcode.gentracker.config.SettingsLoader"
                            serviceImplementation="com.qihoo.finance.lowcode.gentracker.config.GenerateSettingsLoader"/>
        <applicationConfigurable dynamic="true" instance="com.qihoo.finance.lowcode.common.ui.MainSettingForm"/>
        <notificationGroup id="TrackNotify" displayType="BALLOON"/>
        <notificationGroup id="jarvisStickyNotifications" displayType="STICKY_BALLOON"/>

        <!--Jira-commit-->
        <applicationService serviceImplementation="org.qifu.devops.ide.plugins.jiracommit.configuration.JiraCommitSettingState"/>
        <notificationGroup id="Qifu Devops Message Notification Group" displayType="BALLOON"/>

        <!--api design-->
        <projectService serviceImplementation="com.qihoo.finance.lowcode.apitrack.ui.ApiMainPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.apitrack.ui.ApiTreePanel"/>
        <postStartupActivity implementation="com.qihoo.finance.lowcode.common.update.PluginUpdateStartupActivity" />

        <!--code review-->
        <projectService serviceImplementation="com.qihoo.finance.lowcode.codereview.ui.CodeRvMainPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.codereview.ui.CodeRvAuthPanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.codereview.ui.CodeRvTreePanel"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.codereview.ui.CodeRvTaskPanel"/>
        <!--<toolWindow id="Code Review" anchor="bottom" factoryClass="com.qihoo.finance.lowcode.codereview.toolwindow.factory.CodeRvToolWindowFactory" />-->

        <!-- ai question -->
        <projectService serviceImplementation="com.qihoo.finance.lowcode.common.factory.ChatXToolWindowFactory"/>
        <projectService serviceImplementation="com.qihoo.finance.lowcode.aiquestion.ui.QuestionPanel"/>
        <projectService serviceImplementation="com.qifu.ui.smartconversation.sse.AgentCompletionRequestService"/>

        <!-- editor -->
        <codeInsight.daemonBoundCodeVisionProvider implementation="com.qihoo.finance.lowcode.editor.codeInsight.ChatxDaemonBoundCodeVisionProvider"/>
<!--        <codeInsight.codeVisionProvider implementation="com.qihoo.finance.lowcode.editor.codeInsight.ChatxCodeVisionProvider"/>-->
        <applicationService serviceImplementation="com.qihoo.finance.lowcode.editor.ChatxEditorActionTracker"/>
        <applicationService serviceImplementation="com.qihoo.finance.lowcode.status.ChatxStatusService" />
        <applicationService serviceInterface="com.qihoo.finance.lowcode.editor.ChatxService" serviceImplementation="com.qihoo.finance.lowcode.editor.lang.agent.AgentChatxService" />
        <applicationService serviceImplementation="com.qihoo.finance.lowcode.settings.ChatxApplicationSettings"/>
        <applicationService serviceInterface="com.qihoo.finance.lowcode.editor.completions.ChatxCompletionService" serviceImplementation="com.qihoo.finance.lowcode.editor.lang.agent.ChatxAgentCompletionService"/>
        <applicationService serviceInterface="com.qihoo.finance.lowcode.editor.ChatxEditorManager" serviceImplementation="com.qihoo.finance.lowcode.editor.ChatxEditorManagerImpl"/>
        <applicationService serviceImplementation="com.qihoo.finance.lowcode.smartconversation.conversations.ConversationsState"/>
        <editorFactoryListener implementation="com.qihoo.finance.lowcode.editor.ChatxEditorListener"/>
        <editorFactoryListener implementation="com.qifu.ui.smartconversation.JarvisEditorFactoryListener"/>

        <typedHandler order="first, before completionAutoPopup" implementation="com.qihoo.finance.lowcode.editor.TypeOverHandler"/>
        <typedHandler order="first, before completionAutoPopup" implementation="com.qihoo.finance.lowcode.editor.CompletionPopupInhibitor"/>
        <intentionAction>
            <className>com.qihoo.finance.lowcode.editor.action.GenerateCodeByCommentIntentionAction</className>
            <category>JARVIS</category>
        </intentionAction>

        <!-- status bar -->
        <statusBarWidgetFactory order="first" id="ChatX.editorStatusBar" implementation="com.qihoo.finance.lowcode.editor.statusBar.EditorStatusBarWidgetFactory"/>

        <!-- ide event dispatcher -->
        <!--<ideEventQueueDispatcher implementation="com.qihoo.finance.lowcode.editor.action.GenerateCodeByCommentAction$DoubleEnterClickEventDispatcher"/>-->

        <!-- "last" overrides previous promoters, see com.intellij.openapi.keymap.impl.IdeKeyEventDispatcher.rearrangeByPromoters -->
        <actionPromoter order="last" implementation="com.qihoo.finance.lowcode.editor.action.ChatxActionPromoter"/>

        <!--声明式SQL-->
        <editorFloatingToolbarProvider implementation="com.qihoo.finance.lowcode.declarative.action.editor.DeclarativeFloatingToolbarProvider"
                                       id="DeclarativeFloatingToolbarProvider"/>
        <postStartupActivity implementation="com.qifu.listener.JarvisProjectStartupActivity" />
    </extensions>


    <actions>
        <action id="ChatX.ConsoleView.AskAI" class="com.qihoo.finance.lowcode.aiquestion.ui.search.action.ConsoleAskAIAction">
            <add-to-group group-id="ConsoleEditorPopupMenu" anchor="first"/>
            <keyboard-shortcut first-keystroke="alt A" keymap="$default"/>
            <keyboard-shortcut first-keystroke="meta A" keymap="Mac OS X" replace-all="true"/>
            <keyboard-shortcut first-keystroke="meta A" keymap="Mac OS X 10.5+" replace-all="true"/>
        </action>

        <!--Jira-commit-->
        <action id="action.CommitHelperAction"
                class="org.qifu.devops.ide.plugins.jiracommit.action.JiraCommitHelperAction"
                text="CommitHelper"
                description="点击填写辅助提交注释内容">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>

        <!--SQL编辑器相关-->
        <group id="ChatX.ActionGroup.SQLFileEditor" text="File Editor Controls">
            <action id="ChatX.Actions.CurrentSchema"
                    class="com.qihoo.finance.lowcode.console.mysql.execute.action.SelectSchemaAction"
                    text="选择目标数据库">
            </action>
            <action id="ChatX.Actions.SaveSQL"
                    class="com.qihoo.finance.lowcode.console.mysql.execute.action.SaveSQLAction"
                    text="保存SQL语句" icon="/img/action/save_sql.svg">
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>
            <action id="ChatX.Actions.RenameSQL"
                    class="com.qihoo.finance.lowcode.console.mysql.execute.action.RenameSQLAction"
                    text="重命名SQL语句" icon="/img/action/rename.svg">
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>
            <action id="ChatX.Actions.SQLExecute"
                    class="com.qihoo.finance.lowcode.console.mysql.execute.action.ExecuteSQLAction"
                    text="执行SQL - 支持选中执行" icon="/img/action/StatementExecution.png">
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>
        </group>

        <!-- editor -->
        <action id="Chatx.applyInlays" class="com.qihoo.finance.lowcode.editor.action.ChatxApplyInlaysAction">
            <keyboard-shortcut first-keystroke="TAB" keymap="$default" />
            <override-text place="MainMenu" text="Apply Completions to Editor" />
            <!-- EditorPopup is the place used for the context menu of inlays -->
            <override-text place="EditorPopup" text="Accept" />
        </action>

        <action id="Chatx.applyInlaysNextWord" class="com.qihoo.finance.lowcode.editor.action.ChatxApplyNextWordInlaysAction">
            <keyboard-shortcut first-keystroke="control RIGHT" keymap="$default"/>
            <override-text place="MainMenu" text="Apply Next Word of Completion to Editor"/>
            <!-- EditorPopup is the place used for the context menu of inlays -->
            <override-text place="EditorPopup" text="Accept Next Word"/>
        </action>

        <action id="Chatx.applyInlaysNextLine" class="com.qihoo.finance.lowcode.editor.action.ChatxApplyNextLineInlayAction">
            <keyboard-shortcut first-keystroke="control alt RIGHT" keymap="$default"/>
            <keyboard-shortcut first-keystroke="control meta RIGHT" keymap="Mac OS X" replace-all="true"/>
            <keyboard-shortcut first-keystroke="control meta RIGHT" keymap="Mac OS X 10.5+" replace-all="true"/>
            <override-text place="MainMenu" text="Apply Next Line of Completion to Editor"/>
            <!-- EditorPopup is the place used for the context menu of inlays -->
            <override-text place="EditorPopup" text="Accept Next Line"/>
        </action>

        <action id="Chatx.disposeInlays" class="com.qihoo.finance.lowcode.editor.action.ChatxDisposeInlaysAction" text="Hide Completions in Editor">
            <keyboard-shortcut first-keystroke="ESCAPE" keymap="$default" />
            <override-text place="MainMenu" text="Hide Completions in Editor" />
        </action>
        <action id="Chatx.GenerateCodeByComment" class="com.qihoo.finance.lowcode.editor.action.GenerateCodeByCommentAction">
            <keyboard-shortcut first-keystroke="ENTER" second-keystroke="ENTER" keymap="$default" />
        </action>


        <action id="Chatx.loginChatx" class="com.qihoo.finance.lowcode.editor.action.LoginToChatxAction" />
        <action id="Chatx.logoutChatx" class="com.qihoo.finance.lowcode.editor.action.LogoutFromChatxAction" />
        <action id="Chatx.enableChatx" class="com.qihoo.finance.lowcode.editor.action.EnableChatxCompletionsAction" />
        <action id="Chatx.disableChatx" use-shortcut-of="Chatx.enableChatx" class="com.qihoo.finance.lowcode.editor.action.DisableGlobalChatxCompletionsAction" />
        <action id="Chatx.disableChatxFile" use-shortcut-of="Chatx.enableChatx" class="com.qihoo.finance.lowcode.editor.action.DisableFileChatxCompletionsAction" />
        <action id="Chatx.enableSyntaxCorrection" class="com.qihoo.finance.lowcode.editor.action.EnableSyntaxCorrectionAction" />
        <action id="Chatx.editSetting" class="com.qihoo.finance.lowcode.settings.action.EditSettingAction"/>

        <!-- Shown as popup menu in the status bar for status "notSignedIn" -->
        <group id="Chatx.notSignedInStatusBarPopup">
            <reference id="Chatx.loginChatx" />
            <reference id="Chatx.enableChatx" />
            <reference id="Chatx.disableChatx" />
            <reference id="Chatx.editSetting" />
        </group>
        <!-- Shown as popup menu in the status bar for status "Ready" -->
        <group id="Chatx.statusBarPopup">
           <!-- <reference id="Chatx.logoutChatx" />-->
            <reference id="Chatx.enableChatx" />
            <reference id="Chatx.disableChatx" />
            <reference id="Chatx.disableChatxFile" />
            <!--<reference id="Chatx.enableSyntaxCorrection" />-->
            <reference id="Chatx.editSetting" />
        </group>
        <!-- Shown as popup menu in the status bar for status needing an IDE restart -->
        <group id="Chatx.statusBarRestartPopup">
            <reference id="RestartIde" />
        </group>
        <group id="Chatx.statusBarErrorPopup">
            <reference id="Chatx.loginChatx" />
        </group>

        <!--declarative sql change-->
        <action id="Chatx.declarative" class="com.qihoo.finance.lowcode.declarative.action.DeclarativeSQLAction">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
        </action>
        <group id="Chatx.declarative.floating">
            <reference id="Chatx.declarative" />
        </group>

        <!--lineMarker-->
        <action id="Chatx.lineMarker.askAI" class="com.qihoo.finance.lowcode.aiquestion.ui.search.action.LineMarkerAction" />

        <action id="Chatx.editor.translate" class="com.qihoo.finance.lowcode.editor.intention.TranslateAction"
                text="Jarvis Translate" description="Jarvis Translate">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut first-keystroke="control shift X" keymap="$default"/>
            <keyboard-shortcut first-keystroke="control meta O" keymap="Mac OS X" replace-all="true"/>
            <keyboard-shortcut first-keystroke="control meta O" keymap="Mac OS X 10.5+" replace-all="true"/>
        </action>

        <!-- Add to Jarvis Chat -->
        <action id="Chatx.editor.addToJarvisChat" 
                class="com.qifu.ui.smartconversation.action.AddToJarvisChatAction"
                text="Add to Jarvis Chat" 
                description="Send selected code to Jarvis Chat"
                icon="/icons/status/chatx_3.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <add-to-group group-id="Floating.CodeToolbar" anchor="last"/>
            <keyboard-shortcut first-keystroke="control alt K" keymap="$default"/>
            <keyboard-shortcut first-keystroke="control meta K" keymap="Mac OS X" replace-all="true"/>
            <keyboard-shortcut first-keystroke="control meta K" keymap="Mac OS X 10.5+" replace-all="true"/>
        </action>
    </actions>

    <applicationListeners>
<!--        <listener class="com.qihoo.finance.lowcode.gentracker.listener.ReadOnlyFileListener"-->
<!--                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>-->
        <listener class="com.qihoo.finance.lowcode.editor.ChatxEditorActionTracker$ActionListener"
                  topic="com.intellij.openapi.actionSystem.ex.AnActionListener"/>
        <listener class="com.qifu.listener.JarvisAppLifeListener" topic="com.intellij.ide.AppLifecycleListener" />
    </applicationListeners>

    <projectListeners>
        <!--SQL编辑器开启监听-->
        <listener topic="com.intellij.openapi.fileEditor.FileEditorManagerListener" class="com.qihoo.finance.lowcode.console.mysql.execute.listener.SQLEditorFileListener"/>
<!--        <listener topic="com.intellij.openapi.fileEditor.FileEditorManagerListener" class="com.qihoo.finance.lowcode.editor.intention.TranslateFileListener"/>-->
        <listener class="com.qihoo.finance.lowcode.editor.ChatxLookupListener" topic="com.intellij.codeInsight.lookup.LookupManagerListener"/>
        <listener class="com.qihoo.finance.lowcode.editor.ChatxCommandListener" topic="com.intellij.openapi.command.CommandListener"/>
        <listener class="com.qihoo.finance.lowcode.editor.EditorFocusListener" topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
        <listener class="com.qihoo.finance.lowcode.common.listener.ChatxPluginUnloadListener" topic="com.intellij.ide.plugins.DynamicPluginListener" />
    </projectListeners>

</idea-plugin>
